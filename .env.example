# ──────────────────────────────────────────────
#  ChoiChoi POS — 환경 변수 템플릿
#  실제 값을 채운 뒤 .env 로 복사하세요.
#  이 파일(.env.example)은 커밋해도 안전합니다.
# ──────────────────────────────────────────────

# Supabase 프로젝트 URL
# Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon(public) 키 — 브라우저에 노출되어도 안전
# Supabase Dashboard → Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ⚠ Service Role 키 — RLS를 우회하는 서버 전용 키
# 절대 NEXT_PUBLIC_ 접두사 사용 금지 (클라이언트 번들에 포함되지 않아야 함)
# Supabase Dashboard → Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# 회원가입 초대 코드 — 이 값을 알아야 회원가입 가능 (서버 전용, NEXT_PUBLIC_ 없이)
SIGNUP_CODE=<your-signup-invite-code>

# ⚠ ADMIN_PASSWORD / POPUP_PASSWORD 제거됨 — 인증은 Supabase Auth 단일 시스템으로 대체
# Supabase Dashboard > Authentication > Users 에서 admin 계정 직접 등록 (이메일+비번)

# Discord Webhook URL — 메뉴 설정 변경 시 알림 전송 (선택)
# Discord 채널 설정 → 연동 → 웹후크 에서 발급
DISCORD_WEBHOOK_URL=<your-discord-webhook-url>

# Google Gemini API 키 — AI 매출 분석 기능에 사용
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=<your-gemini-api-key>
